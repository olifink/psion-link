/* Type-checking scope for the framework-free protocol core (src/protocol),
   including its bun:test specs. Not part of the Angular build — see
   tsconfig.app.json for that. */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["bun-types", "w3c-web-serial"]
  },
  "include": ["src/protocol/**/*.ts"]
}
